generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMINISTRATOR
  EDITOR
  VIEWER
}

enum AdminInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model Redirect {
  id             String       @id @default(cuid())
  code           String       @unique
  destinationUrl String       @map("destination_url")
  title          String
  category       String       @default("General")
  purpose        String       @default("General")
  tags           String[]     @default([])
  description    String?
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  createdBy      String       @map("created_by")
  updatedBy      String       @map("updated_by")
  clickEvents    ClickEvent[]

  @@index([createdAt])
  @@index([updatedAt])
  @@index([category])
  @@index([purpose])
  @@map("redirects")
}

model ClickEvent {
  id            String    @id @default(cuid())
  redirectId    String?   @map("redirect_id")
  redirect      Redirect? @relation(fields: [redirectId], references: [id], onDelete: SetNull)
  requestedCode String    @map("requested_code")
  redirectUrl   String?   @map("redirect_url")
  outcome       String
  referrer      String?
  referrerHost  String?   @map("referrer_host")
  userAgent     String?   @map("user_agent")
  ipHash        String?   @map("ip_hash")
  country       String?
  region        String?
  city          String?
  timezone      String?
  latitude      String?
  longitude     String?
  utmSource     String?   @map("utm_source")
  utmMedium     String?   @map("utm_medium")
  utmCampaign   String?   @map("utm_campaign")
  utmContent    String?   @map("utm_content")
  utmTerm       String?   @map("utm_term")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([redirectId, createdAt])
  @@index([requestedCode, createdAt])
  @@index([redirectUrl, createdAt])
  @@index([createdAt])
  @@index([country, createdAt])
  @@index([utmCampaign, createdAt])
  @@map("click_events")
}

model RedirectCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String   @map("created_by")
  updatedBy   String   @map("updated_by")

  @@map("redirect_categories")
}

model RedirectTag {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  @@map("redirect_tags")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String   @map("updated_by")

  @@map("settings")
}

model AdminUser {
  id          String    @id @default(cuid())
  email       String    @unique
  firstName   String?   @map("first_name")
  lastName    String?   @map("last_name")
  clerkUserId String?   @unique @map("clerk_user_id")
  role        AdminRole
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdBy   String    @map("created_by")
  updatedBy   String    @map("updated_by")

  @@index([role])
  @@map("admin_users")
}

model AdminInvitation {
  id                String                @id @default(cuid())
  email             String
  firstName         String                @map("first_name")
  lastName          String                @map("last_name")
  role              AdminRole
  status            AdminInvitationStatus @default(PENDING)
  clerkInvitationId String                @unique @map("clerk_invitation_id")
  invitationUrl     String?               @map("invitation_url")
  expiresAt         DateTime              @map("expires_at")
  acceptedAt        DateTime?             @map("accepted_at")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  createdBy         String                @map("created_by")
  updatedBy         String                @map("updated_by")

  @@index([email, status])
  @@index([status, expiresAt])
  @@map("admin_invitations")
}
